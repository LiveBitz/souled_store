// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // ✅ PHASE 1: Connection pool - requires DATABASE_DIRECT_URL env var for pooling
  // This allows 20 concurrent connections instead of default 2-5
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  image     String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // ✅ PHASE 1: Index for category page queries (/category/[slug])
  @@index([slug])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  category      Category @relation(fields: [categoryId], references: [id])
  categoryId    String
  subCategory   String
  price         Float
  originalPrice Float
  discount      Int      @default(0)
  stock         Int      @default(0) // Stock quantity - 0 means out of stock
  sizes         String[] // Supported in PostgreSQL
  colors        String[] 
  image         String
  images        String[] 
  description   String   @default("")
  features      String[] @default([])
  isNew         Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  wishlists        Wishlist[]
  orderItems       OrderItem[]
  offlineSaleItems OfflineSaleItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ✅ Performance Indexes
  @@index([categoryId])      // For filtering by category
  @@index([isNew])          // For "New Arrivals" section
  @@index([isBestSeller])   // For "Best Sellers" section
  @@index([slug])           // PHASE 1: Product detail page queries (/product/[slug])
  @@index([createdAt])      // PHASE 1: Sorting by creation date (new arrivals)
  @@index([name])           // PHASE 2 FIX: Index for search queries on product name
  @@index([stock])          // For filtering products with stock
}

model ItemTag {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandTag {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id          String   @id @default(cuid())
  type        String   // HERO, PROMO, etc.
  title       String
  subtitle    String?
  image       String
  buttonText  String?  @default("Shop Now")
  link        String?  @default("/")
  order       Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Address {
  id        String   @id @default(cuid())
  userId    String   // Link to Supabase User ID
  name      String
  phone     String
  street    String
  city      String
  state     String
  zipCode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   // Link to Supabase User ID
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String      // Link to Supabase User ID
  orderNumber   String      @unique
  
  // Customer Info
  customerName  String
  customerEmail String
  customerPhone String
  
  // Delivery Address
  street        String
  city          String
  state         String
  zipCode       String
  
  // Order Details
  items         OrderItem[]
  subtotal      Float
  tax           Float       @default(0)
  shipping      Float       @default(0)
  total         Float
  
  // Status & Payment
  status        String      @default("pending") // pending, confirmed, shipped, delivered, cancelled
  paymentMethod String      @default("cod") // cod = Cash on Delivery
  paymentStatus String      @default("pending") // pending, completed
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([userId])
  @@index([orderNumber])
  @@index([status])        // ✅ For filtering orders by status
  @@index([userId, createdAt])  // ✅ For user's order history with sorting
  @@index([status, createdAt])  // ✅ PHASE 6: For dashboard status breakdown queries
  @@index([createdAt])     // ✅ PHASE 6: For time-based filtering
}

model OrderItem {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String

  quantity  Int
  price     Float    // Price at time of purchase
  size      String?
  color     String?

  @@index([orderId])
  @@index([productId])
  @@index([productId, orderId])  // ✅ PHASE 6: Composite for grouping top products
}

model OfflineSale {
  id            String            @id @default(cuid())
  saleNumber    String            @unique
  customerName  String?
  customerPhone String?
  items         OfflineSaleItem[]
  subtotal      Float
  discount      Float             @default(0)
  total         Float
  paymentMethod String            @default("cash") // cash, upi, card
  paymentStatus String            @default("paid")
  notes         String?
  soldBy        String?
  saleDate      DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([saleDate])
  @@index([paymentMethod])
  @@index([createdAt])
}

model OfflineSaleItem {
  id          String       @id @default(cuid())
  saleId      String
  sale        OfflineSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  brandName   String?
  productName String
  quantity    Int
  price       Float
  total       Float

  @@index([saleId])
  @@index([productId])
}
